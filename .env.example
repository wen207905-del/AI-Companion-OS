# DeepSeek
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-chat

# Qwen（阿里云 MaaS / DashScope 兼容模式）
QWEN_API_KEY=sk-your-qwen-key
QWEN_BASE_URL=https://ws-hzh7mdnpcm0fjcrc.cn-beijing.maas.aliyuncs.com
QWEN_MODEL=qwen3.7-plus

# 主对话 LLM（默认 DeepSeek）
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat

# 辅助 LLM 默认值（可被每个会话覆盖）
LLM_AUX_PROVIDER=deepseek
LLM_AUX_MODEL=deepseek-chat

# 用户档案（与 config/user.yaml 同步）
USER_NAME=许汉文
USER_NICKNAME=汉文

# 生成参数
LLM_TEMPERATURE=0.85
LLM_MAX_TOKENS=512
LLM_PRIVATE_MAX_TOKENS=1536
LLM_TIMEOUT=120
LLM_STREAM=true
# 风格参考长文注入（默认关闭）
STYLE_REFERENCE_ENABLED=false
# 角色回复后生成「内心独白」（多一次 LLM 调用；默认关闭）
LLM_INNER_THOUGHT=false
# 用户可见聊天/叙述模式（默认关闭，忽略持久化 mode）
ENABLE_MANUAL_MODE=false
# 私聊/群聊跳过短回复强制扩写
PRIVATE_SKIP_EXPAND=true
GROUP_SKIP_EXPAND=true
# 群聊默认一名角色回复；角色自动接话默认关闭
GROUP_MAX_RESPONDERS=1
GROUP_CHAIN_ENABLED=false
# 私聊正文和私聊长期记忆禁止进入群 Prompt
GROUP_PRIVATE_BRIDGE_ENABLED=false
GROUP_PRIVATE_MEMORY_IN_PROMPT=false
# 允许角色知道“近期私聊发生过”，只延续态度，不注入私聊内容
GROUP_PRIVATE_CONTINUITY_ENABLED=true
GROUP_MAX_REPLY_CHARS=450
GROUP_MAX_TOKENS=700
GROUP_TEMPERATURE=0.75
# 正式环境填写前端来源，例如 https://companion.example.com
CORS_ALLOW_ORIGINS=

# standard=默认 | unrestricted=私聊无审查
CONTENT_MODE=unrestricted

# 硅基流动生图（V4 Image Engine）
SILICONFLOW_API_KEY=sk-your-siliconflow-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
IMAGE_CONTENT_MODE=unrestricted
IMAGE_OUTPUT_DIR=data/albums

SERVER_HOST=0.0.0.0
SERVER_PORT=8000
