# DeepSeek
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-chat

# Qwen（阿里云 MaaS / DashScope 兼容模式）
QWEN_API_KEY=sk-your-qwen-key
QWEN_BASE_URL=https://ws-hzh7mdnpcm0fjcrc.cn-beijing.maas.aliyuncs.com
QWEN_MODEL=qwen3.7-plus

# 主对话 LLM（默认 DeepSeek）
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat

# 辅助 LLM 默认值（可被每个会话覆盖）
LLM_AUX_PROVIDER=deepseek
LLM_AUX_MODEL=deepseek-chat

# 用户档案（与 config/user.yaml 同步）
USER_NAME=许汉文
USER_NICKNAME=汉文

# 生成参数
LLM_TEMPERATURE=0.85
LLM_MAX_TOKENS=512
LLM_TIMEOUT=120
LLM_STREAM=true
# 角色回复后生成「内心独白」（多一次 LLM 调用，略慢）
LLM_INNER_THOUGHT=true

# standard=默认 | unrestricted=私聊无审查
CONTENT_MODE=unrestricted

SERVER_HOST=0.0.0.0
SERVER_PORT=8000
